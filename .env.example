# Version de PocketBase à utiliser — https://github.com/pocketbase/pocketbase/releases
PB_VERSION=0.38.1

# Port exposé sur la machine hôte
APP_PORT=80

# URL PocketBase exposée au navigateur
# En local : http://localhost (ou http://localhost:<APP_PORT> si différent de 80)
VITE_POCKETBASE_URL=http://localhost
