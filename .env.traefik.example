# Version de PocketBase à utiliser — https://github.com/pocketbase/pocketbase/releases
PB_VERSION=0.38.1

# Nom utilisé pour les routeurs et middlewares Traefik (sans espaces ni caractères spéciaux)
APP_NAME=steinbp

# Domaine public de l'application
APP_DOMAIN=steinbp.example.com

# URL PocketBase exposée au navigateur (généralement https://<APP_DOMAIN>)
VITE_POCKETBASE_URL=https://steinbp.example.com

# Nom du cert resolver configuré dans Traefik — doit correspondre EXACTEMENT au nom
# défini dans certificatesResolvers de traefik.yml (ex: letsencrypt, myhttpchallenge)
TRAEFIK_CERT_RESOLVER=myhttpchallenge

# Middlewares Traefik pour le routeur HTTPS sécurisé.
# Doit toujours inclure <APP_NAME>-headers@docker.
# Ajoutez vos propres middlewares séparés par des virgules (ex: crowdsec@docker).
TRAEFIK_SECURED_MIDDLEWARES=steinbp-headers@docker
